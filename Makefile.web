CC      = emcc
CFLAGS  = -std=c99 -O2 -s USE_SDL=2
SRC     = src/main.c src/game.c src/platform_sdl2.c
OUT     = build/web/breakout.html

all: $(OUT)

$(OUT): $(SRC) src/game.h src/platform.h src/shell.html
	mkdir -p build/web
	$(CC) $(CFLAGS) -o $(OUT) $(SRC) \
		--shell-file src/shell.html

clean:
	rm -rf build/web

.PHONY: all clean
