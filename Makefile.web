CC      = emcc
CFLAGS  = -std=c99 -O2 -s USE_SDL=2
SRC     = src/main.c src/game.c src/platform_sdl2.c
OUT     = build/web/breakout.js

all: build/web/breakout.html

$(OUT): $(SRC) src/game.h src/platform.h
	mkdir -p build/web
	$(CC) $(CFLAGS) -o $(OUT) $(SRC)

build/web/breakout.html: $(OUT) src/shell.html
	cp src/shell.html build/web/breakout.html

clean:
	rm -rf build/web

.PHONY: all clean
